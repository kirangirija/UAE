# Copy this file to .env and fill in your keys. .env is gitignored.
OPENROUTER_API_KEY=
# Model used for the AI Q&A / narrative-insight features (OpenRouter model id).
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Google Sign-In (OAuth client credentials from Google Cloud Console).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Any long random string — used to sign session cookies. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=
# The only email allowed to view /admin/stats.
ADMIN_EMAIL=kiramani@gmail.com
# Must exactly match the app's externally-reachable base URL — used to build
# the OAuth redirect_uri. Locally: http://localhost:8420. In production:
# https://uae-real-estate-dashboard.onrender.com
PUBLIC_BASE_URL=http://localhost:8420

# Login/usage analytics storage (Supabase project "uae-real-estate-dashboard").
# The anon/publishable key is safe to ship — access to the users/page_views
# tables is scoped by RLS policies on the Supabase side, not by key secrecy.
SUPABASE_URL=
SUPABASE_ANON_KEY=
